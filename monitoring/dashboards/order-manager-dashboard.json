      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "up{job=\"order-manager\"}",
          "legendFormat": "API",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
